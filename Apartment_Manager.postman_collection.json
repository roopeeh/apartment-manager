{
  "info": {
    "name": "Apartment Manager API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://prod-mh-api.manato.in", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "society_id", "value": "", "type": "string" },
    { "key": "flat_id", "value": "", "type": "string" },
    { "key": "resident_id", "value": "", "type": "string" },
    { "key": "payment_id", "value": "", "type": "string" },
    { "key": "expense_id", "value": "", "type": "string" },
    { "key": "notice_id", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\",\n  \"phone\": \"+91-9876543210\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  const data = json.data || json;",
                  "  pm.collectionVariables.set('access_token', data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', data.refresh_token);",
                  "  if (data.roles && data.roles.length > 0 && data.roles[0].society_id) {",
                  "    pm.collectionVariables.set('society_id', data.roles[0].society_id);",
                  "  }",
                  "  console.log('Token saved. Society ID:', pm.collectionVariables.get('society_id'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  const data = json.data || json;",
                  "  pm.collectionVariables.set('access_token', data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', data.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"RESET_TOKEN_HERE\",\n  \"new_password\": \"NewPassword123!\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"Password123!\",\n  \"new_password\": \"NewPassword123!\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Platform (Super Admin)",
      "item": [
        {
          "name": "Platform Stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/platform/stats"
          }
        },
        {
          "name": "List Societies",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/platform/societies?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "platform", "societies"],
              "query": [
                { "key": "status", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true },
                { "key": "city", "value": "", "disabled": true },
                { "key": "plan", "value": "", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Create Society",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  const data = json.data || json;",
                  "  if (data.society && data.society.id) {",
                  "    pm.collectionVariables.set('society_id', data.society.id);",
                  "    console.log('Society ID saved:', data.society.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/platform/societies",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sunshine Apartments\",\n  \"address\": \"123 Main Street\",\n  \"city\": \"Mumbai\",\n  \"phone\": \"+91-9876543210\",\n  \"email\": \"society@example.com\",\n  \"total_blocks\": 2,\n  \"blocks\": [\"A\", \"B\"],\n  \"floors\": [1, 2, 3, 4],\n  \"plan\": \"basic\",\n  \"admin\": {\n    \"name\": \"Society Admin\",\n    \"email\": \"admin@sunshine.com\",\n    \"phone\": \"+91-9876543211\",\n    \"password\": \"Admin@123!\"\n  }\n}"
            }
          }
        },
        {
          "name": "Update Society",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/platform/societies/{{society_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sunshine Apartments Updated\",\n  \"city\": \"Pune\",\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "Delete Society",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/platform/societies/{{society_id}}"
          }
        },
        {
          "name": "Society Audit",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/platform/societies/{{society_id}}/audit"
          }
        }
      ]
    },
    {
      "name": "Societies",
      "item": [
        {
          "name": "Get Society",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/societies/{{society_id}}"
          }
        },
        {
          "name": "Update Society",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/societies/{{society_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Society Name\",\n  \"address\": \"456 New Street\"\n}"
            }
          }
        }
      ]
    },

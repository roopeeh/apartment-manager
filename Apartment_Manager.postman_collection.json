    {
      "name": "Payments",
      "item": [
        {
          "name": "Payment Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/societies/{{society_id}}/payments/summary?year=2024",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "societies", "{{society_id}}", "payments", "summary"],
              "query": [{ "key": "year", "value": "2024" }]
            }
          }
        },
        {
          "name": "List Payments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/societies/{{society_id}}/payments?page=1&limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "societies", "{{society_id}}", "payments"],
              "query": [
                { "key": "month", "value": "", "disabled": true },
                { "key": "year", "value": "", "disabled": true },
                { "key": "status", "value": "", "disabled": true },
                { "key": "block", "value": "", "disabled": true },
                { "key": "flat_id", "value": "", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Generate Bills",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/societies/{{society_id}}/payments/generate-bills",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"month\": \"January\",\n  \"year\": 2024\n}"
            }
          }
        },
        {
          "name": "Record Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  const data = json.data || json;",
                  "  if (data.id) {",
                  "    pm.collectionVariables.set('payment_id', data.id);",
                  "    console.log('Payment ID saved:', data.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/v1/societies/{{society_id}}/payments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flat_id\": \"{{flat_id}}\",\n  \"month\": \"January\",\n  \"year\": 2024,\n  \"amount_paid\": 2500,\n  \"payment_mode\": \"upi\",\n  \"payment_date\": \"2024-01-15\",\n  \"transaction_ref\": \"UPI123456\",\n  \"remarks\": \"January maintenance\"\n}"
            }
          }
        },
        {
          "name": "Update Payment",
